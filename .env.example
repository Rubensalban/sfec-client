# URL de base de l'API SFEC (HTTPS obligatoire, sauf localhost pour tests)
# Exemples : https://sandbox-sfecapi.akieni.tech/api ou https://sfec.gouv.cg/api
SFEC_CLIENT_BASE_URL=
# Cle API obtenue via le portail e-Facture (mode ERP)
SFEC_CLIENT_API_KEY=
# Label informatif optionnel (ex: sandbox, production, staging)
SFEC_CLIENT_ENV=sandbox
